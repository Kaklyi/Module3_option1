START

// Declare variables
DECLARE income AS DOUBLE
DECLARE taxWithholding AS DOUBLE
DECLARE taxRate AS DOUBLE

// Ask the user for weekly income
DISPLAY "Enter your weekly income:"
INPUT income

// Determine tax rate based on income bracket
IF income < 500 THEN
    SET taxRate = 0.10
ELSE IF income >= 500 AND income < 1500 THEN
    SET taxRate = 0.15
ELSE IF income >= 1500 AND income < 2500 THEN
    SET taxRate = 0.20
ELSE
    SET taxRate = 0.30
END IF

// Calculate tax withholding
SET taxWithholding = income * taxRate

// Display result
DISPLAY taxWithholding

END
